<InputPlayersAmountScreen>:
    BoxLayout:
        orientation: 'vertical'
        
        # --- HEADER BAR ---
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: 0.1
            padding: [10, 5, 10, 5]
            canvas.before:
                Color:
                    rgba: (0.15, 0.15, 0.15, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size

            Button:
                text: "<"
                font_size: '22sp'
                size_hint_x: 0.15
                on_release: 
                    root.manager.transition.direction = 'left'
                    root.manager.current = 'role_selection_screen'

            Label:
                text: "Assigning Roles"
                font_size: '20sp'
                bold: True
                size_hint_x: 0.70
                halign: 'center'
            
            Widget:
                size_hint_x: 0.15