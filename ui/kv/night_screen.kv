<NightScreen>:
    BoxLayout:
        orientation: 'vertical'
        
        # --- HEADER BAR ---
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: 0.1
            padding: [10, 5, 10, 5]
            canvas.before:
                Color:
                    rgba: (0.15, 0.15, 0.15, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size

            Button:
                text: "⚙️"
                font_name: "ui/fonts/twemoji.ttf"
                font_size: '22sp'
                size_hint_x: 0.15
                on_release: 
                    root.manager.transition.direction = 'right'
                    root.manager.current = 'main_menu_screen'

            Label:
                text: "Night Cycle"
                font_size: '20sp'
                bold: True
                size_hint_x: 0.70
                halign: 'center'
            
            Button:
                text: "⏸️"
                font_name: "ui/fonts/twemoji.ttf"
                font_size: '35sp'
                size_hint_x: 0.15
                background_color: (0.4, 0.4, 0.6, 1)
                on_release: 
                    root.default_roles()

        # --- SCROLLABLE LIST AREA ---
        ScrollView:
            do_scroll_x: False
            do_scroll_y: True

            BoxLayout:
                id: players_container_night
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                on_minimum_height: self.height = args[1]
                padding: [10, 10, 10, 80]
                spacing: 10


<PlayerItem>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(80)
    padding: dp(10)
    spacing: dp(15)
    
    canvas.before:
        Color:
            rgba: (0.2, 0.2, 0.2, 1)
        Rectangle:
            pos: self.pos
            size: self.size

    # Left: Emoji (20% width)
    Label:
        text: root.emoji if root.show_role_emoji else root.default_emoji
        font_size: '40sp'
        font_name: "ui/fonts/twemoji.ttf"
        size_hint_x: 0.2
        halign: 'center'
        valign: 'middle'
        text_size: self.size

    # Middle: Player Name (50% width)
    Label:
        text: root.player_name
        font_size: '18sp'
        bold: True
        size_hint_x: 0.5
        halign: 'left'
        valign: 'middle'
        text_size: self.size

    # Right: Configurable Action Button (30% width)
    Button:
        text: root.action_button_text
        font_size: '16sp'
        size_hint_x: 0.3
        on_release: root.vote()


<LoadingOverlay@ModalView>:
    # This color is [R, G, B, A]. Grey with 0.5 alpha:
    background_color: [0.2, 0.2, 0.2, 0.5]
    background: '' # Removes the default Kivy background image texture
    
    # Prevents the user from closing the overlay by clicking outside of it
    auto_dismiss: False 
    
    BoxLayout:
        orientation: 'vertical'
        size_hint: (None, None)
        size: ('200dp', '100dp')
        pos_hint: {'center_x': 0.5, 'center_y': 0.5}
        
        Label:
            text: "new night"
            font_size: '20sp'
            bold: True
            
        Button:
            text: "Dismiss"
            size_hint_y: None
            height: '40dp'
            on_press: root.dismiss()