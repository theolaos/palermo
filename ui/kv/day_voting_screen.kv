<DayVotingScreen>:
    BoxLayout:
        orientation: 'vertical'
        
        # --- HEADER BAR ---
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: 0.1
            padding: [10, 5, 10, 5]
            canvas.before:
                Color:
                    rgba: (0.15, 0.15, 0.15, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size

            # Button:
            #     text: "<"
            #     font_size: '22sp'
            #     size_hint_x: 0.15
            #     on_release: 
            #         root.manager.transition.direction = 'right'
            #         root.manager.current = 'main_menu_screen'

            Label:
                text: "Night Cycle"
                font_size: '20sp'
                bold: True
                size_hint_x: 0.70
                halign: 'center'
            
            # Button:
            #     text: "🔄"
            #     font_name: "ui/fonts/twemoji.ttf"
            #     font_size: '35sp'
            #     size_hint_x: 0.15
            #     background_color: (0.4, 0.4, 0.6, 1)
            #     on_release: 
            #         root.default_roles()

        # --- SCROLLABLE LIST AREA ---
        ScrollView:
            do_scroll_x: False
            do_scroll_y: True

            BoxLayout:
                id: players_container
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                on_minimum_height: self.height = args[1]
                padding: [10, 10, 10, 80]
                spacing: 10
        
        Button:
            text: root.bottom_button
            font_size: '20sp'
            bold: True
            size_hint: (1, 0.08)
            pos_hint: {'center_x': 0.5, 'y': 0.03}  # Centered horizontally, 3% up from the bottom boundary
            background_color: root.bottom_bg_color # Green color accent
            on_release: root.press_next_day()