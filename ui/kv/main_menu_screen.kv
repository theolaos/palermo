<MainMenuScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 40
        spacing: 20

        Label:
            text: "Palermo"
            font_size: '36sp'
            bold: True
            size_hint_y: 0.2

        # Pushes the button toward the middle/bottom of the screen
        Widget:
            size_hint_y: 0.4

        Button:
            text: "PLAY"
            font_size: '24sp'
            size_hint_y: 0.15
            background_color: (0.2, 0.6, 1, 1) # Optional: light blue color
            on_release: 
                root.default_roles()
                
                root.manager.transition.direction = 'left'
                root.manager.current = 'role_selection_screen'


        Button:
            text: "NETWORK"
            font_size: '20sp'
            size_hint_y: 0.12
            on_release: print("Credits pressed")


        Button:
            text: "SETTINGS"
            font_size: '20sp'
            size_hint_y: 0.12
            # You can link this to a settings screen later
            on_release: print("Settings pressed")


        Button:
            text: "CREDITS"
            font_size: '20sp'
            size_hint_y: 0.12
            on_release: print("Credits pressed")

        Widget:
            size_hint_y: 0.4