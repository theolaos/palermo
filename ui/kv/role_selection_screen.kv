<RoleSelectionScreen>:
    BoxLayout:
        orientation: 'vertical'
        
        # --- HEADER BAR ---
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: 0.1
            padding: [10, 5, 10, 5]
            canvas.before:
                Color:
                    rgba: (0.15, 0.15, 0.15, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size

            Button:
                text: "<"
                font_size: '22sp'
                size_hint_x: 0.15
                on_release: 
                    root.manager.transition.direction = 'right'
                    root.manager.current = 'main_menu_screen'

            Label:
                text: "Choose roles"
                font_size: '20sp'
                bold: True
                size_hint_x: 0.70
                halign: 'center'
            
            Button:
                text: "🔄"
                font_name: "ui/fonts/twemoji.ttf"
                font_size: '35sp'
                size_hint_x: 0.15
                background_color: (0.4, 0.4, 0.6, 1)
                on_release: 
                    root.default_roles()

        # --- SCROLLABLE LIST AREA ---
        ScrollView:
            do_scroll_x: False
            do_scroll_y: True

            BoxLayout:
                id: roles_container
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                on_minimum_height: self.height = args[1]
                padding: [10, 10, 10, 80]
                spacing: 10
        
        Button:
            text: "NEXT"
            font_size: '20sp'
            bold: True
            size_hint: (0.9, 0.08)  # 90% of screen width, 8% of screen height
            pos_hint: {'center_x': 0.5, 'y': 0.03}  # Centered horizontally, 3% up from the bottom boundary
            background_color: (0.2, 0.8, 0.4, 1) # Green color accent
            on_release: 
                root.manager.transition.direction = 'left'
                root.manager.current = 'input_players_amount_screen'


# --- CUSTOM ROLE ITEM TEMPLATE ---
<InputAmountPlayers>:
    orientation: 'vertical'     # Matches RoleItem structure
    size_hint_y: None
    height: dp(80)              # Matching base height
    padding: 5
    spacing: 10

    canvas.before:
        Color:
            rgba: (0.2, 0.2, 0.2, 1)  # Matches standard item color
        Rectangle:
            pos: self.pos
            size: self.size

    # Main Row Container
    BoxLayout:
        orientation: 'horizontal'
        size_hint_y: 1          # Let it take up the full parent height
        padding: 5
        spacing: 10

        # Left Side: Emoji Icon
        Label:
            text: "👥"
            font_size: '60sp'   # Adjusted from 100sp so it fits neatly inside the dp(80) boundary
            font_name: "ui/fonts/twemoji.ttf"
            size_hint_x: 0.2    # Matches the exact horizontal footprint of the RoleItem images
            halign: 'center'
            valign: 'middle'
            text_size: self.size

        # Middle Side: Label Explanation
        BoxLayout:
            orientation: 'vertical'
            size_hint_x: 0.5    # Matches the middle text block spacing
            
            Label:
                text: "Amount of players"
                font_size: '18sp'   # Matches role title font size
                bold: True
                text_size: self.size
                halign: 'left'
                valign: 'middle'

        # Right Side: Interactive Input Field
        BoxLayout:
            orientation: 'horizontal'
            size_hint_x: 0.3    # Matches the right column spacing (- number +)
            padding: [0, 10, 0, 10] # Vertical centering alignment padding

            TextInput:
                id: player_count_input
                text: root.get_text()
                multiline: False
                input_filter: 'int'
                font_size: '18sp'
                halign: 'center'
                valign: 'middle'
                size_hint: (1, 1) # Let it smoothly occupy the assigned 30% right area
                on_text_validate: root.validate_player_count(self.text)
                on_focus: if not self.focus: root.validate_player_count(self.text)


<RoleItem>:
    orientation: 'vertical'
    size_hint_y: None
    height: dp(80)  # Default collapsed height
    on_touch_down: root.toggle_expand(args[1])
    
    canvas.before:
        Color:
            rgba: (0.2, 0.2, 0.2, 1) if not root.is_expanded else (0.25, 0.25, 0.25, 1)
        Rectangle:
            pos: self.pos
            size: self.size

    # Main Row (Image, Text, Counter)
    BoxLayout:
        orientation: 'horizontal'
        size_hint_y: None
        height: dp(80)
        padding: 5
        spacing: 10

        # Left: Picture Placeholder (Using an Image widget)
        Label:
            text: root.emoji
            font_size: '60sp'   # Adjusted from 100sp so it fits neatly inside the dp(80) boundary
            font_name: "ui/fonts/twemoji.ttf"
            size_hint_x: 0.2    # Matches the exact horizontal footprint of the RoleItem images
            halign: 'center'
            valign: 'middle'
            text_size: self.size

        # Middle: Text Info
        BoxLayout:
            orientation: 'vertical'
            size_hint_x: 0.5
            alignment: 'left'
            
            Label:
                text: root.role_name
                font_size: '18sp'
                bold: True
                text_size: self.size
                halign: 'left'
                valign: 'middle'
            Label:
                text: root.short_desc
                font_size: '13sp'
                color: (0.7, 0.7, 0.7, 1)
                text_size: self.size
                halign: 'left'
                valign: 'top'

        # Right: Counter (- Number +)
        BoxLayout:
            orientation: 'horizontal'
            size_hint_x: 0.3
            spacing: 5
            padding: [0, 15, 0, 15] # Centers the buttons vertically

            Button:
                id: minus_btn
                text: "-"
                font_size: '18sp'
                on_release: root.decrement()

            Label:
                text: str(root.count)
                font_size: '16sp'
                bold: True

            Button:
                id: plus_btn
                text: "+"
                font_size: '18sp'
                on_release: root.increment()

    # Expandable Description Container
    Label:
        id: extra_desc
        text: ""
        font_size: '14sp'
        text_size: self.width - 20, None
        size_hint_y: None
        height: self.texture_size[1] if root.is_expanded else 0
        padding: [10, 10]
        halign: 'left'
        valign: 'top'